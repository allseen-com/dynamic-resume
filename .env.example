# Add these in Vercel: Project Settings → Environment Variables (do not commit .env or .env.local)

# AI provider (openai | anthropic | google | ollama). Default: openai
AI_PROVIDER=openai
OPENAI_API_KEY=

# Optional: override model
# OPENAI_MODEL=gpt-4o-mini

# Optional: Pinecone for vector search and resume–job match score
# Create an index with dimension 1536 (OpenAI text-embedding-3-small), cosine metric
PINECONE_API_KEY=
PINECONE_INDEX=
PINECONE_NAMESPACE=resume-chunks

# Optional: lock optimization/archive/settings/admin/mother-resume APIs behind a session cookie.
# If BOTH are set, visitors only see the public resume at / unless they unlock at /unlock.
# Generate a long random string for each (e.g. openssl rand -hex 32).
# TOOLING_UNLOCK_TOKEN — you enter this once on /unlock; TOOLING_SESSION_VALUE — stored in HttpOnly cookie.
TOOLING_UNLOCK_TOKEN=
TOOLING_SESSION_VALUE=
